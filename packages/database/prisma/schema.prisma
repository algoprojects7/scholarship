generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum AdminType {
  SUPER
  OPERATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ALLOCATED
}

enum DocumentType {
  AADHAAR
  INCOME_CERTIFICATE
  MARKSHEET
  BANK_PASSBOOK
  FEE_RECEIPT
  PHOTO
}

enum DocumentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ScholarshipType {
  ONE_TIME
  YEARLY
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum PaymentType {
  YEARLY
  SEMESTER
  ONE_TIME
}

enum RemarkAction {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DOCUMENT_REJECTED
  ALLOCATION_CREATED
  REALLOCATED
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  role            UserRole
  isActive        Boolean   @default(true) @map("is_active")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentProfile       StudentProfile?
  admin                Admin?
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model StudentProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  fullName    String   @map("full_name") @db.VarChar(100)
  gender      Gender
  countryCode String   @default("+91") @map("country_code") @db.VarChar(4)
  mobile      String   @unique @db.VarChar(10)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("student_profiles")
}

model Admin {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  adminType   AdminType @map("admin_type")
  fullName    String    @map("full_name") @db.VarChar(100)
  employeeId  String    @unique @map("employee_id") @db.VarChar(50)
  department  String?   @db.VarChar(100)
  countryCode String    @default("+91") @map("country_code") @db.VarChar(4)
  phone       String?   @db.VarChar(10)
  createdById String?   @map("created_by") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy            Admin?                @relation("AdminCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAdmins        Admin[]               @relation("AdminCreatedBy")
  reviewedApplications Application[]         @relation("ApplicationReviewedBy")
  verifiedDocuments    ApplicationDocument[] @relation("DocumentVerifiedBy")
  remarks              ApplicationRemark[]
  allocations          ScholarshipAllocation[] @relation("AllocationCreatedBy")
  auditLogs            AuditLog[]

  @@index([adminType], map: "idx_admins_admin_type")
  @@map("admins")
}

model Application {
  id                  String            @id @default(uuid()) @db.Uuid
  studentId           String            @map("student_id") @db.Uuid
  applicationNumber   String?           @unique @map("application_number") @db.VarChar(20)
  status              ApplicationStatus @default(DRAFT)
  academicYear        String            @map("academic_year") @db.VarChar(9)
  personalDetails     Json?             @map("personal_details") @db.JsonB
  educationalDetails  Json?             @map("educational_details") @db.JsonB
  contactAddress      Json?             @map("contact_address") @db.JsonB
  bankDetails         Json?             @map("bank_details") @db.JsonB
  feeDetails          Json?             @map("fee_details") @db.JsonB
  submittedAt         DateTime?         @map("submitted_at") @db.Timestamptz(6)
  reviewedAt          DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  reviewedById        String?           @map("reviewed_by") @db.Uuid
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  student      StudentProfile          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy   Admin?                  @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  feePayments  FeePayment[]
  documents    ApplicationDocument[]
  remarks      ApplicationRemark[]
  allocations  ScholarshipAllocation[]

  @@index([studentId], map: "idx_applications_student_id")
  @@index([status], map: "idx_applications_status")
  @@index([academicYear], map: "idx_applications_academic_year")
  @@index([submittedAt(sort: Desc)], map: "idx_applications_submitted_at")
  @@map("applications")
}

model FeePayment {
  id            String  @id @default(uuid()) @db.Uuid
  applicationId String  @map("application_id") @db.Uuid
  year          Int     @db.SmallInt
  amountPaid    Decimal @map("amount_paid") @db.Decimal(12, 2)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, year])
  @@map("fee_payments")
}

model ApplicationDocument {
  id                 String                     @id @default(uuid()) @db.Uuid
  applicationId      String                     @map("application_id") @db.Uuid
  documentType       DocumentType               @map("document_type")
  fileName           String                     @map("file_name") @db.VarChar(255)
  fileUrl            String                     @map("file_url") @db.VarChar(500)
  fileSize           Int?                       @map("file_size")
  mimeType           String?                    @map("mime_type") @db.VarChar(50)
  verificationStatus DocumentVerificationStatus @default(PENDING) @map("verification_status")
  verifiedById       String?                    @map("verified_by") @db.Uuid
  verifiedAt         DateTime?                  @map("verified_at") @db.Timestamptz(6)
  rejectionReason    String?                    @map("rejection_reason") @db.Text
  uploadedAt         DateTime                   @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy  Admin?      @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@unique([applicationId, documentType])
  @@index([applicationId], map: "idx_documents_application_id")
  @@map("application_documents")
}

model ApplicationRemark {
  id            String       @id @default(uuid()) @db.Uuid
  applicationId String       @map("application_id") @db.Uuid
  adminId       String       @map("admin_id") @db.Uuid
  remark        String       @db.Text
  action        RemarkAction
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  admin       Admin       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([applicationId], map: "idx_remarks_application_id")
  @@map("application_remarks")
}

model ScholarshipAllocation {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @map("application_id") @db.Uuid
  allocatedById String          @map("allocated_by") @db.Uuid
  type          ScholarshipType
  amount        Decimal         @db.Decimal(12, 2)
  academicYear  String          @map("academic_year") @db.VarChar(9)
  paymentStatus PaymentStatus   @default(PENDING) @map("payment_status")
  paymentDate   DateTime?       @map("payment_date") @db.Timestamptz(6)
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  allocatedBy Admin       @relation("AllocationCreatedBy", fields: [allocatedById], references: [id], onDelete: Restrict)

  @@unique([applicationId, academicYear])
  @@index([academicYear], map: "idx_allocations_academic_year")
  @@map("scholarship_allocations")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String?  @map("admin_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?    @db.JsonB
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  admin Admin? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([adminId], map: "idx_audit_logs_admin_id")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
