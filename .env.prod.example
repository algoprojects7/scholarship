# Production environment template (Dokploy / Hostinger VPS)
# Copy values into Dokploy env panels per application — do not commit real secrets.

# --- Domains ---
SITE_NAME=scholarship.example.com
SITE_URL=https://scholarship.example.com
ADMIN_URL=https://admin.scholarship.example.com
API_URL=https://api.scholarship.example.com
CORS_ORIGINS=https://scholarship.example.com,https://admin.scholarship.example.com

# --- Database (Dokploy PostgreSQL service) ---
DATABASE_URL=postgresql://USER:PASSWORD@postgres-host:5432/scholarship?schema=public

# --- Redis (Dokploy Redis service) ---
REDIS_URL=redis://redis-host:6379

# --- JWT (generate long random strings) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Object storage (Hostinger S3, Cloudflare R2, or MinIO on VPS) ---
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=scholarship-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# --- API ---
PORT=4000
NODE_ENV=production
# SWAGGER_ENABLED=false

# --- Seed (run once after first deploy) ---
SEED_SUPER_ADMIN_EMAIL=super@scholarship.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMeAfterFirstLogin!

# --- Frontend build-time (Dokploy env for web / admin-web apps) ---
NEXT_PUBLIC_API_URL=https://api.scholarship.example.com
NEXT_PUBLIC_SITE_URL=https://scholarship.example.com
NEXT_PUBLIC_PORTAL=admin
