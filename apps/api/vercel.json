{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "public",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "cd ../.. && pnpm run db:generate && pnpm run build --filter=@scholarship/api",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{dist/**,../../packages/database/dist/**,../../packages/shared/dist/**,../../node_modules/.prisma/**}"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
